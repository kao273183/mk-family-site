---
import { t, toggleLocaleHref, localePath, type Lang } from "../i18n";

export interface Props {
  title: string;
  description: string;
  ogImage?: string;
  canonical?: string;
  lang: Lang;
}
const { title, description, ogImage = "/assets/og-image.png", canonical, lang } = Astro.props;
const url = canonical ?? Astro.url.href;
const tr = t(lang);
const langPath = Astro.url.pathname;
const oppositeLangHref = toggleLocaleHref(langPath, lang);
const htmlLang = lang === "zh-tw" ? "zh-Hant" : "en";
---
<!DOCTYPE html>
<html lang={htmlLang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="theme-color" content="#0B1628" />
  <link rel="icon" type="image/png" href="/assets/logo.png" />
  <link rel="apple-touch-icon" href="/assets/logo.png" />
  <link rel="canonical" href={url} />

  <meta property="og:type" content="website" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={url} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:locale" content={lang === "zh-tw" ? "zh_TW" : "en_US"} />
  <meta property="og:locale:alternate" content={lang === "zh-tw" ? "en_US" : "zh_TW"} />

  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Serif+TC:wght@400;700;900&family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet" />

  <style is:global>
    :root {
      --bg: #0B1628;
      --bg-elev: #0E1A2D;
      --bg-card: #111E33;
      --bg-card-hover: #15243C;
      --border: rgba(240, 237, 230, 0.08);
      --border-strong: rgba(240, 237, 230, 0.16);
      --text: #F0EDE6;
      --muted: rgba(240, 237, 230, 0.55);
      --dim: rgba(240, 237, 230, 0.32);
      --accent: #D4A843;
      --accent-2: #E8C36B;
      --accent-glow: rgba(212, 168, 67, 0.22);
      --gold-dim: rgba(212, 168, 67, 0.15);
      --border-gold: rgba(212, 168, 67, 0.3);
      --green: #6BB97A;
      --yellow: #E8C36B;
      --red: #D87568;
      --mono: 'DM Mono', 'SF Mono', Menlo, Consolas, ui-monospace, monospace;
      --sans: 'DM Sans', -apple-system, BlinkMacSystemFont, 'PingFang TC', 'Microsoft JhengHei', sans-serif;
      --serif: 'Noto Serif TC', Georgia, serif;
      --radius: 12px;
      --radius-lg: 18px;
    }
    * { box-sizing: border-box; }
    html { scroll-behavior: smooth; }
    html, body { margin: 0; padding: 0; }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      font-size: 16px;
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }
    body::before {
      content: "";
      position: fixed; inset: 0;
      background:
        radial-gradient(ellipse 70% 50% at 50% -10%, rgba(212, 168, 67, 0.10), transparent 70%),
        radial-gradient(ellipse 60% 40% at 90% 10%, rgba(212, 168, 67, 0.05), transparent 70%);
      pointer-events: none;
      z-index: 0;
    }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
    .container { max-width: 1120px; margin: 0 auto; padding: 0 28px; position: relative; z-index: 1; }

    /* Nav */
    nav.top {
      position: sticky; top: 0; z-index: 50;
      backdrop-filter: blur(14px);
      -webkit-backdrop-filter: blur(14px);
      background: rgba(11, 22, 40, 0.72);
      border-bottom: 1px solid var(--border);
    }
    nav.top .container {
      display: flex; align-items: center; justify-content: space-between;
      height: 62px;
    }
    .brand {
      font-family: var(--mono);
      font-weight: 600;
      font-size: 14px;
      color: var(--text);
      display: flex; align-items: center; gap: 10px;
    }
    .brand img { width: 22px; height: 22px; border-radius: 6px; }
    .brand .dot { color: var(--accent); }
    .nav-links { display: flex; gap: 24px; }
    .nav-links a {
      font-family: var(--mono);
      font-size: 13px;
      color: var(--muted);
      transition: color 120ms;
    }
    .nav-links a:hover { color: var(--text); text-decoration: none; }
    .nav-links a.active { color: var(--accent); }
    .nav-actions { display: flex; gap: 14px; align-items: center; }
    .lang-toggle {
      font-family: var(--mono);
      font-size: 12px;
      color: var(--muted);
      padding: 6px 10px;
      border: 1px solid var(--border);
      border-radius: 8px;
      transition: all 120ms;
    }
    .lang-toggle:hover { color: var(--accent); border-color: var(--border-strong); text-decoration: none; }
    .btn {
      display: inline-flex; align-items: center; gap: 8px;
      padding: 10px 18px;
      border-radius: var(--radius);
      font-family: var(--mono); font-size: 13px; font-weight: 500;
      transition: all 120ms;
      cursor: pointer; border: none;
      text-decoration: none;
    }
    .btn-primary {
      background: var(--accent);
      color: #0B1628;
    }
    .btn-primary:hover {
      background: var(--accent-2);
      text-decoration: none;
      transform: translateY(-1px);
    }
    .btn-ghost {
      background: transparent;
      color: var(--text);
      border: 1px solid var(--border-strong);
    }
    .btn-ghost:hover {
      border-color: var(--accent);
      color: var(--accent);
      text-decoration: none;
    }
    .btn-sm { padding: 7px 13px; font-size: 12px; }

    /* Sections */
    section.block { padding: 100px 0; position: relative; }
    .section-head { text-align: center; max-width: 760px; margin: 0 auto 64px; }
    .section-eyebrow {
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 12px;
    }
    .section-title {
      font-family: var(--serif);
      font-size: 44px;
      line-height: 1.15;
      font-weight: 700;
      margin: 0 0 18px;
      letter-spacing: -0.01em;
    }
    .section-title .accent { color: var(--accent); font-style: italic; }
    .section-sub {
      color: var(--muted);
      font-size: 17px;
      line-height: 1.65;
      margin: 0;
    }
    .grid-4 { display: grid; gap: 20px; grid-template-columns: repeat(4, minmax(0, 1fr)); }
    .grid-3 { display: grid; gap: 24px; grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .grid-2 { display: grid; gap: 24px; grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 32px;
      transition: all 160ms;
    }
    .card:hover {
      background: var(--bg-card-hover);
      border-color: var(--border-strong);
      transform: translateY(-2px);
    }
    .card .icon {
      font-family: var(--mono);
      font-size: 22px;
      color: var(--accent);
      margin-bottom: 12px;
    }
    .card h3 {
      font-family: var(--serif);
      font-size: 22px;
      line-height: 1.3;
      margin: 0 0 12px;
      font-weight: 700;
    }
    .card .role {
      font-family: var(--mono);
      font-size: 11px;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 14px;
    }
    .card p { margin: 0 0 14px; color: var(--muted); line-height: 1.65; }
    .card ul { margin: 14px 0 18px; padding-left: 18px; color: var(--muted); }
    .card ul li { margin: 6px 0; line-height: 1.55; }
    .card code, .markdown-block code {
      font-family: var(--mono); font-size: 12px;
      background: rgba(212, 168, 67, 0.08);
      color: var(--accent-2);
      padding: 2px 6px; border-radius: 4px;
    }
    .badge {
      display: inline-block;
      font-family: var(--mono);
      font-size: 11px;
      padding: 4px 10px;
      border-radius: 999px;
      background: var(--gold-dim);
      color: var(--accent-2);
      border: 1px solid var(--border-gold);
      letter-spacing: 0.08em;
    }
    .badge.muted {
      background: rgba(240, 237, 230, 0.04);
      color: var(--muted);
      border-color: var(--border);
    }
    pre {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 24px;
      overflow-x: auto;
      font-family: var(--mono);
      font-size: 13px;
      line-height: 1.7;
      color: var(--text);
    }

    /* Hero */
    .hero {
      padding: 80px 0 100px;
      text-align: center;
      position: relative;
    }
    .hero-logo {
      width: 220px; height: 220px;
      border-radius: 40px;
      margin: 0 auto 32px;
      display: block;
    }
    @media (max-width: 760px) {
      .hero-logo { width: 160px; height: 160px; border-radius: 28px; margin-bottom: 24px; }
    }
    .eyebrow {
      display: inline-block;
      font-family: var(--mono);
      font-size: 12px;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 18px;
    }
    .hero-title {
      font-family: var(--serif);
      font-size: 64px;
      line-height: 1.05;
      font-weight: 900;
      margin: 0 0 16px;
      letter-spacing: -0.02em;
    }
    .hero-title .accent { color: var(--accent); font-style: italic; }
    .hero-alt-name {
      font-family: var(--mono);
      font-size: 13px;
      letter-spacing: 0.22em;
      color: var(--dim);
      margin: 0 0 22px;
    }
    .hero-sub {
      font-size: 19px;
      color: var(--muted);
      max-width: 720px;
      margin: 0 auto 32px;
      line-height: 1.6;
    }
    .cta-row {
      display: flex; gap: 14px; justify-content: center; flex-wrap: wrap;
      margin: 0 auto 60px;
    }

    /* Compat */
    .compat { text-align: center; margin: 36px 0; }
    .compat-label {
      font-family: var(--mono); font-size: 12px;
      letter-spacing: 0.1em; color: var(--dim);
      text-transform: uppercase;
      margin-bottom: 14px;
    }
    .compat-row {
      display: flex; gap: 8px; justify-content: center; flex-wrap: wrap;
    }
    .pill {
      font-family: var(--mono); font-size: 12px;
      padding: 6px 14px;
      border-radius: 999px;
      background: rgba(240, 237, 230, 0.04);
      border: 1px solid var(--border);
      color: var(--muted);
    }
    .pill.new {
      background: var(--gold-dim);
      color: var(--accent-2);
      border-color: var(--border-gold);
    }

    /* Terminal */
    .terminal {
      background: var(--bg-elev);
      border: 1px solid var(--border-strong);
      border-radius: var(--radius-lg);
      max-width: 760px; margin: 40px auto 0;
      overflow: hidden;
      text-align: left;
      box-shadow: 0 20px 60px rgba(0,0,0,0.45);
    }
    .terminal-bar {
      display: flex; align-items: center; gap: 10px;
      padding: 12px 16px;
      background: rgba(255,255,255,0.02);
      border-bottom: 1px solid var(--border);
      font-family: var(--mono); font-size: 12px;
      color: var(--muted);
    }
    .terminal-bar .dots { display: flex; gap: 6px; }
    .terminal-bar .dot {
      width: 11px; height: 11px; border-radius: 50%;
      display: inline-block;
    }
    .terminal-bar .dot.r { background: #FF5F57; }
    .terminal-bar .dot.y { background: #FEBC2E; }
    .terminal-bar .dot.g { background: #28C840; }
    .terminal-body {
      padding: 18px 20px;
      font-family: var(--mono); font-size: 13px;
      line-height: 1.9;
    }
    .terminal-body .prompt { color: var(--accent); font-weight: 600; }
    .terminal-body .user { color: var(--text); }
    .terminal-body .cmt { color: var(--dim); }
    .terminal-body .out { color: var(--muted); }
    .terminal-body .ok { color: var(--green); }
    .terminal-body .warn { color: var(--yellow); }
    .terminal-body .cursor {
      display: inline-block; width: 8px; height: 14px;
      background: var(--accent); vertical-align: middle;
      margin-left: 4px;
      animation: blink 1s steps(1) infinite;
    }
    @keyframes blink { 50% { opacity: 0; } }

    /* Layer block (vertical timeline) */
    .layer-list { display: grid; gap: 16px; }
    .layer-row {
      display: grid;
      grid-template-columns: 130px 1fr;
      gap: 24px; align-items: start;
      padding: 24px;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
    }
    .layer-row .layer-label {
      font-family: var(--mono); font-size: 12px;
      color: var(--accent); letter-spacing: 0.12em;
      text-transform: uppercase;
    }
    .layer-row .layer-body {
      color: var(--muted); font-size: 15px;
      line-height: 1.7;
    }
    .layer-row .layer-body h4 {
      font-family: var(--serif); margin: 0 0 8px;
      color: var(--text); font-size: 18px; font-weight: 700;
    }

    /* Tools grid */
    .tools-grid {
      display: grid; gap: 20px;
      grid-template-columns: repeat(2, 1fr);
    }
    .tool-cat {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 22px;
    }
    .tool-cat .label {
      font-family: var(--mono); font-size: 11px;
      color: var(--accent); letter-spacing: 0.14em;
      text-transform: uppercase;
      margin-bottom: 12px;
    }
    .tool-cat .items {
      display: flex; flex-wrap: wrap; gap: 6px;
    }
    .tool-cat .items code, .tool-cat code {
      font-family: var(--mono); font-size: 12px;
      background: rgba(212, 168, 67, 0.06);
      color: var(--accent-2);
      padding: 3px 8px; border-radius: 6px;
      border: 1px solid var(--border);
    }
    .tool-cat ul {
      list-style: none; padding: 0; margin: 0;
    }
    .tool-cat ul li {
      padding: 6px 0;
      color: var(--muted);
      font-size: 14px;
      line-height: 1.5;
    }
    .tool-cat ul li code {
      margin-right: 6px;
    }

    /* Pipeline */
    .pipeline {
      display: grid;
      grid-template-columns: repeat(6, minmax(0, 1fr));
      gap: 14px;
      align-items: stretch;
      margin: 0 auto;
      max-width: 1140px;
    }
    .pipe-step {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
      padding: 22px 18px;
      position: relative;
    }
    .pipe-step.pipe-step--external {
      background: transparent;
      border-style: dashed;
      border-color: var(--dim);
    }
    .pipe-step.pipe-step--external .pipe-owner {
      color: var(--muted);
    }
    .pipe-step:not(:last-child)::after {
      content: "→";
      position: absolute;
      right: -22px; top: 50%;
      transform: translateY(-50%);
      color: var(--accent);
      font-family: var(--mono);
      font-size: 24px;
      z-index: 2;
    }
    .pipe-step .pipe-name {
      font-family: var(--serif);
      font-size: 22px;
      color: var(--text);
      margin-bottom: 6px;
      font-weight: 700;
    }
    .pipe-step .pipe-owner {
      font-family: var(--mono);
      font-size: 11px;
      color: var(--accent);
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 12px;
    }
    .pipe-step .pipe-blurb {
      color: var(--muted);
      font-size: 13px;
      line-height: 1.6;
    }

    /* Final CTA */
    .final-cta {
      text-align: center;
      background: linear-gradient(180deg, rgba(212, 168, 67, 0.08), transparent);
      padding: 80px 28px;
      border: 1px solid var(--border);
      border-radius: var(--radius-lg);
    }
    .final-cta h2 {
      font-family: var(--serif);
      font-size: 38px;
      margin: 0 0 14px;
    }
    .final-cta p { color: var(--muted); margin: 0 0 26px; }

    /* Footer */
    footer {
      padding: 60px 0;
      border-top: 1px solid var(--border);
      margin-top: 80px;
    }
    footer .container {
      display: flex; flex-direction: column; align-items: center; gap: 22px;
    }
    footer .links { display: flex; gap: 22px; flex-wrap: wrap; justify-content: center; }
    footer .links a {
      font-family: var(--mono); font-size: 12px;
      color: var(--muted);
    }
    footer .links a:hover { color: var(--accent); text-decoration: none; }
    footer .meta {
      font-family: var(--mono); font-size: 11px; color: var(--dim);
    }

    @media (max-width: 1180px) {
      .section-title { font-size: 36px; }
    }
    @media (max-width: 1024px) {
      .pipeline { grid-template-columns: 1fr; max-width: 560px; }
      .pipe-step:not(:last-child)::after { content: "↓"; right: auto; left: 50%; top: auto; bottom: -22px; transform: translateX(-50%); }
    }

    @media (max-width: 880px) {
      .tools-grid { grid-template-columns: 1fr; }
    }
    @media (max-width: 760px) {
      .hero-title { font-size: 40px; }
      .hero-sub { font-size: 16px; }
      .section-title { font-size: 28px; line-height: 1.2; }
      .section-head { margin-bottom: 40px; }
      section.block { padding: 64px 0; }
      .grid-3, .grid-2, .grid-4 { grid-template-columns: 1fr; }
      .layer-row { grid-template-columns: 1fr; gap: 8px; }
      .container { padding: 0 20px; }
      nav.top .container { height: 56px; }
      .nav-links { gap: 14px; }
      .nav-links a { font-size: 12px; }
      .brand { font-size: 12px; }
      .brand img { width: 20px; height: 20px; }
      .lang-toggle { padding: 5px 8px; font-size: 11px; }
      .pipe-step { padding: 18px 16px; }
      .pipe-step .pipe-name { font-size: 20px; }
      .card { padding: 24px; }
    }
    @media (max-width: 480px) {
      .hero-title { font-size: 32px; }
      .section-title { font-size: 24px; }
      .nav-links { gap: 10px; }
      .nav-links a { font-size: 11px; }
      .brand .dot { display: none; }
    }
  </style>
</head>
<body>
  <nav class="top">
    <div class="container">
      <a href={localePath(lang, "/")} class="brand">
        <img src="/assets/logo.png" alt="" />
        mk-family<span class="dot">.</span>
      </a>
      <div class="nav-links">
        <a href={localePath(lang, "/")}>{tr.nav.family}</a>
        <a href={localePath(lang, "plan-master")}>{tr.nav.plan}</a>
        <a href={localePath(lang, "spec-master")}>{tr.nav.spec}</a>
        <a href={localePath(lang, "qa-master")}>{tr.nav.qa}</a>
      </div>
      <div class="nav-actions">
        <a class="lang-toggle" href={oppositeLangHref}>
          {lang === "en" ? "EN / 中" : "EN / 中"}
        </a>
        <a class="btn btn-ghost btn-sm" href="https://github.com/kao273183">{tr.nav.github}</a>
      </div>
    </div>
  </nav>

  <slot />

  <footer>
    <div class="container">
      <div class="links">
        <a href={localePath(lang, "/")}>{tr.nav.family}</a>
        <a href={localePath(lang, "plan-master")}>mk-plan-master</a>
        <a href={localePath(lang, "spec-master")}>mk-spec-master</a>
        <a href={localePath(lang, "qa-master")}>mk-qa-master</a>
        <a href="https://github.com/kao273183">GitHub</a>
        <a href="https://www.buymeacoffee.com/minikao" target="_blank" rel="noopener" style="color: #FFDD00;">{tr.footer.support}</a>
      </div>
      <div class="meta">{tr.footer.builtBy} <strong style="color: var(--text); font-weight: 500;">Jack.Kao</strong> @ <a href="https://chenjundigital.com" style="color: var(--accent);">宸鈞數位</a> →</div>
    </div>
  </footer>
</body>
</html>
