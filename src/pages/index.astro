---
import Base from "../layouts/Base.astro";
import family from "../data/family.json";
---
<Base
  title="MK Family · AI-QA MCPs for Claude / Cursor / Codex / Gemini"
  description="An opinionated family of open-source MCP servers for AI-driven QA workflows. Spec → test → coverage → coach — each MCP owns one job, together they close the loop."
>
  <section class="hero">
    <div class="container">
      <img src="/assets/logo.png" alt="MK Family" class="hero-logo" />
      <span class="eyebrow">Open source · Model Context Protocol · AI-QA Family</span>
      <h1 class="hero-title">
        The <span class="accent">mk-*</span> family.<br/>
        AI QA, decomposed.
      </h1>
      <p class="hero-alt-name">AI 大師系列 · MK FAMILY</p>
      <p class="hero-sub">
        An opinionated family of MCP servers for AI-driven QA workflows.
        Each member owns one job in the loop — <strong>specs</strong> in,
        <strong>tests</strong> out, <strong>coverage</strong> tracked,
        <strong>suite</strong> coached. Compose them in your Claude / Cursor /
        Codex / Gemini config and let the AI drive.
      </p>
      <div class="cta-row">
        <a class="btn btn-primary" href="#members">Meet the family →</a>
        <a class="btn btn-ghost" href="https://github.com/kao273183">View on GitHub</a>
      </div>
    </div>
  </section>

  <section id="members" class="block">
    <div class="container">
      <div class="section-head">
        <div class="section-eyebrow">Current members</div>
        <h2 class="section-title">Two MCPs. <span class="accent">One loop.</span></h2>
        <p class="section-sub">
          mk-qa-master runs the tests. mk-spec-master tracks what's tested.
          Together they form the spec → test → coverage → coach loop —
          composable in any MCP client, no MCP-to-MCP RPC required.
        </p>
      </div>
      <div class="grid-2">
        {family.members.map((m) => (
          <div class="card">
            <div class="role">{m.role}</div>
            <h3>{m.displayName} <span style="color: var(--dim); font-family: var(--mono); font-size: 14px; font-weight: 400;">·  {m.altName}</span></h3>
            <span class="badge">{m.status}</span> <span class="badge muted">{m.tools} tools</span>
            <p style="margin-top: 18px;">{m.tagline}</p>
            <ul>
              {m.highlights.map((h: string) => <li>{h}</li>)}
            </ul>
            <div style="display: flex; gap: 10px; flex-wrap: wrap;">
              <a class="btn btn-primary btn-sm" href={`/${m.slug}`}>Deep dive →</a>
              <a class="btn btn-ghost btn-sm" href={m.github}>GitHub</a>
              <a class="btn btn-ghost btn-sm" href={m.pypi}>PyPI</a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="block" style="padding-top: 0;">
    <div class="container">
      <div class="section-head">
        <div class="section-eyebrow">Coming soon</div>
        <h2 class="section-title">Two more members <span class="accent">in design</span></h2>
        <p class="section-sub">
          Same coach-layer pattern, different domains. Designed for the same
          MCP client config so adding the next layer is one block of JSON.
        </p>
      </div>
      <div class="grid-2">
        {family.future.map((m) => (
          <div class="card">
            <div class="role" style="color: var(--muted);">In design</div>
            <h3>{m.displayName}</h3>
            <span class="badge muted">{m.status}</span>
            <p style="margin-top: 18px;">{m.tagline}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="block" style="padding-top: 0;">
    <div class="container">
      <div class="section-head">
        <div class="section-eyebrow">Install</div>
        <h2 class="section-title">Drop both into your <span class="accent">MCP client config</span></h2>
        <p class="section-sub">
          One JSON block. The AI client chains them automatically.
        </p>
      </div>
      <pre style="background: var(--bg-card); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 24px; overflow-x: auto; font-family: var(--mono); font-size: 13px; line-height: 1.7; color: var(--text);">{`{
  "mcpServers": {
    "mk-qa-master": {
      "command": "uvx",
      "args": ["mk-qa-master"],
      "env": {
        "QA_RUNNER": "pytest",
        "QA_PROJECT_ROOT": "/path/to/your/project"
      }
    },
    "mk-spec-master": {
      "command": "uvx",
      "args": ["mk-spec-master"],
      "env": {
        "SPEC_SOURCE": "markdown_local",
        "SPEC_PROJECT_ROOT": "/path/to/your/project"
      }
    }
  }
}`}</pre>
    </div>
  </section>
</Base>
